# Same Microsoft Foundry project used by src/ciq_app (see appsettings.json)
AZURE_AI_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4
AZURE_TENANT_ID=

# Agent identity in the Foundry project
FOUNDRY_AGENT_NAME=ciq-client-intelligence-agent

# Foundry IQ - knowledge base files uploaded for RAG grounding (KYC/AML policy docs)
FOUNDRY_KNOWLEDGE_FILES=

# Fabric IQ - Fabric Data Agent connection registered on the Foundry project
FABRIC_CONNECTION_ID=

# Web IQ - Bing grounding connection registered on the Foundry project
BING_CONNECTION_NAME=

# Work IQ (Microsoft 365) has no SDK support and must be added to the agent
# from the Foundry portal: Agents -> select agent -> Knowledge and tools -> Add -> Microsoft 365.
